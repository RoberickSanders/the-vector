# Required: Anthropic API key for Claude integration (used by tailor.py, batch_apply.py, score_resume.py, auto_apply.py).
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api...

# Optional: Hiring manager finder cascade (only needed if using find_managers.py).
# Each step is silently skipped when its key is missing — the cascade falls
# through to the next available source.
BLITZ_API_KEY=
HUNTER_API_KEY=
ICYPEAS_API_KEY=
ICYPEAS_API_SECRET=
MILLIONVERIFIER_API_KEY=
SERPER_API_KEY=

# Optional: Kimi (Moonshot AI) via the Anthropic-compatible endpoint
# (https://api.kimi.com/coding) — used by score.py and career_translator.py
# for cost-efficient batch fit-scoring. Falls back to ANTHROPIC_API_KEY when
# not set.
KIMI_API_KEY=

# Output directory (rendered PDFs, .xlsx exports)
OUTPUT_DIR=./output
